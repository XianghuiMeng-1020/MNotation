{
  "name": "mnotation-web",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "node scripts/generate-headers.mjs && tsc -b && vite build",
    "build:analyze": "node scripts/generate-headers.mjs && tsc -b && vite build --mode analyze",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "deploy": "npm run build && wrangler pages deploy dist"
  },
  "dependencies": {
    "@sentry/react": "^10.47.0",
    "@types/react-window": "^1.8.8",
    "chart.js": "^4.5.1",
    "react": "^19.2.0",
    "react-chartjs-2": "^5.3.1",
    "react-dom": "^19.2.0",
    "react-router-dom": "^7.9.0",
    "react-window": "^2.2.7"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "jsdom": "^26.1.0",
    "rollup-plugin-visualizer": "^6.0.3",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.48.0",
    "vite": "^7.3.1",
    "vitest": "^3.2.4"
  }
}
