{
  "name": "mnotation",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/web"
  ],
  "scripts": {
    "dev:web": "npm --prefix apps/web run dev",
    "build:web": "npm --prefix apps/web run build",
    "lint:web": "npm --prefix apps/web run lint",
    "deploy:web": "npm --prefix apps/web run deploy",
    "deploy:api": "wrangler deploy",
    "d1:migrate": "wrangler d1 migrations apply mnotation_db --local"
  },
  "devDependencies": {
    "wrangler": "^4.40.0"
  }
}
